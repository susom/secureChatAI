{
    "name": "SecureChatAI",
    "namespace": "Stanford\\SecureChatAI",
    "description": "SecureChatAI is an External Module (EM) designed as a service to access Stanford's Instance of OpenAI Models, specifically Secure Chat AI",
    "documentation": "README.md",
    "authors": [
        {
            "name": "Irvin Szeto",
            "email": "irvins@stanford.edu",
            "institution": "Stanford University"
        },
        {
            "name": "Jordan Schultz",
            "email": "jmschult@stanford.edu",
            "institution": "Stanford University"
        },
        {
            "name": "Ihab Zeedia",
            "email": "ihabz@stanford.edu",
            "institution": "Stanford University"
        }
    ],
    "framework-version": 14,
    "enable-every-page-hooks-on-system-pages": false,
    "enable-no-auth-logging": true,
    "links": {
        "project": [
            {
                "name": "AI Usage Dashboard",
                "icon": "fas fa-chart-bar",
                "url": "pages/ProjectUsage.php",
                "show-header-and-footer": true
            }
        ],
        "control-center": [
            {
                "name": "SecureChat Log Visualization",
                "icon": "fa-solid fa-chart-simple",
                "url": "pages/Visualization.php",
                "show-header-and-footer": false
            },
            {
                "name": "SecureChatAI AI Model Smoke Tests",
                "icon": "fa-solid fa-gear",
                "url": "pages/tests.php",
                "show-header-and-footer": false
            }
        ]
    },

    "api-actions": {
        "callAI": {
            "description": "Proxy AI calls (DeepSeek, GPT, etc.) for external pipelines",
            "access": ["auth"]
        },
        "messages": {
            "description": "Claude Messages API compatibility endpoint for Claude Code and Ollama-compatible tools",
            "access": ["auth"]
        }
    },

    "system-settings": [
        {
            "key": "enable_agent_mode",
            "name": "<b>Enable Agent Mode</b><br><i>(system-wide)</i> Allows SecureChatAI to execute agentic workflows when requested by a project. Agent mode is supported only for LLMs that can handle tool use <b>(gpt-4.1, o1, o3-mini, gpt-5, llama3370b)</b>. Ensure REDCap Chatbot EM is configured accordingly per project.",
            "type": "checkbox",
            "required": false
        },
        {
            "key": "agent_tools_redcap_api_url",
            "name": "<b>Agent Tools REDCap API URL</b>",
            "type": "text",
            "required": true,
            "default": "http://localhost/api/"
        },
        {
            "key": "agent_router_system_prompt",
            "name": "<b>Agent Router System Prompt</b><br><i>Defines how the LLM selects and sequences tools during agentic workflows</i>",
            "type": "textarea",
            "required": false
        },
        {
            "key": "agent_tools_project_pid",
            "name": "<b>Agent Tools Project PID</b>",
            "type": "text",
            "required": true
        },
        {
            "key": "agent_tools_project_api_key",
            "name": "<b>Agent Tools Project API Key</b><br><i>API token for the dedicated Agent Tools REDCap project</i>",
            "type": "text",
            "required": true
        },
        {
            "key": "agent_tool_registry",
            "name": "<b>Agent Tool Registry (JSON)</b><br><i>Defines allowed tools for agentic workflows. Project-scoped.</i><br>TODO: automate this",
            "type": "textarea",
            "required": false
        },
        {
            "key": "pre_tool_use_hooks",
            "name": "<b>Pre-Tool-Use Hooks</b><br><i>(optional)</i> Comma-separated class names implementing <code>PreToolUseHook</code>. Runs before each tool call. Can inspect input or deny execution.<br>Example: <code>App\\Hooks\\AuditHook,App\\Hooks\\RateLimitHook</code>",
            "type": "textarea",
            "required": false
        },
        {
            "key": "post_tool_use_hooks",
            "name": "<b>Post-Tool-Use Hooks</b><br><i>(optional)</i> Comma-separated class names implementing <code>PostToolUseHook</code>. Runs after each tool call. Can log results or trigger side-effects.<br>Example: <code>App\\Hooks\\MetricsHook</code>",
            "type": "textarea",
            "required": false
        },
        {
            "key": "agent_tool_em_prefixes",
            "name": "<b>Agent Tool EM Prefixes</b><br><i>(optional)</i> Comma-separated EM prefixes that provide agent tools via <code>agent-tool-definitions</code> in their config.json.<br>Example: <code>redcap_agent_rexi_tools,redcap_agent_foo_tools</code>",
            "type": "textarea",
            "required": false
        },
        {
            "key": "agent_max_steps",
            "name": "<b>Agent: Max Steps Per Loop</b><br><i>Maximum number of agent reasoning iterations</i>",
            "type": "text",
            "default": "8"
        },
        {
            "key": "agent_max_tools_per_run",
            "name": "<b>Agent: Max Tool Calls Per Run</b><br><i>Maximum total tool executions before terminating</i>",
            "type": "text",
            "default": "15"
        },
        {
            "key": "agent_timeout_seconds",
            "name": "<b>Agent: Max Execution Time (seconds)</b><br><i>Maximum wall-clock time for agent loop</i>",
            "type": "text",
            "default": "120"
        },
        {
            "key": "agent_max_subagent_depth",
            "name": "<b>Agent: Max Sub-Agent Depth</b><br><i>How deep sub-agents can spawn children. 0 = disable sub-agents, 1 = one level, 2 = sub-agents can spawn children.</i>",
            "type": "text",
            "default": "1"
        },
        {
            "key": "agent_max_clarifications",
            "name": "<b>Max Agent Clarification Requests</b>",
            "type": "text",
            "default": "2"
        },
        {
            "key": "apim_dns_override_ip",
            "name": "<b>APIM DNS Override IP</b><br><i>(optional)</i> Forces DNS resolution for apim.stanfordhealthcare.org to a specific IP. Only needed for production environments with site-to-site VPN. Leave empty for dev/firewall-based setups.<br>Example: 10.249.134.5",
            "type": "text",
            "required": false
        },
        {
            "key": "api-settings",
            "name": "<b>AI Model API Settings</b>",
            "required": true,
            "type": "sub_settings",
            "repeatable": true,
            "sub_settings": [
                {
                    "key": "model-alias",
                    "name": "<b>Model Alias</b> <i>(e.g., gpt-4o, ada-002)</i>",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "model-id",
                    "name": "<b>Model ID</b> <i>(e.g., Llama-3.3-70B-Instruct, etc)</i>",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "api-url",
                    "name": "<b>API Endpoint</b>",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "api-token",
                    "name": "<b>API Token</b>",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "api-key-var",
                    "name": "<b>API Key Variable Name</b> <i>(e.g., subscription-key, api-key, Ocp-Apim-Subscription-Key)</i>",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "api-input-var",
                    "name": "<b>Model input Variable Name</b> <i>(e.g., messages, input)</i>",
                    "type": "text",
                    "required": true
                },
                {
                    "key": "default-model",
                    "name": "<b>Default Model</b> <i>(Check if this is the default model)</i>",
                    "type": "checkbox",
                    "required": false
                }
            ]
        },
        {
            "key": "gpt-temperature",
            "name": "<b>Temperature</b> default: <i>0.7</i> <br>(Controls randomness)",
            "required": false,
            "type": "number",
            "min": 0,
            "max": 1,
            "default": 0.7
        },
        {
            "key": "gpt-top-p",
            "name": "<b>Top P</b> default: <i>0.9</i> <br>(Controls diversity via nucleus sampling)",
            "required": false,
            "type": "number",
            "min": 0,
            "max": 1,
            "default": 0.9
        },
        {
            "key": "gpt-frequency-penalty",
            "name": "<b>Frequency Penalty</b> default: <i>0.5</i> <br>(Reduces repetition)",
            "required": false,
            "type": "number",
            "min": 0,
            "max": 2,
            "default": 0.5
        },
        {
            "key": "gpt-presence-penalty",
            "name": "<b>Presence Penalty</b> default: <i>0.0</i> <br>(Increases topic variety)",
            "required": false,
            "type": "number",
            "min": 0,
            "max": 2,
            "default": 0.0
        },
        {
            "key": "gpt-max-tokens",
            "name": "<b>Max Tokens</b> default: <i>800</i> <br>(Limits response length)",
            "required": false,
            "type": "number",
            "default": 800
        },
        {
            "key": "reasoning-effort",
            "name": "<b>Reasoning Effort</b>  <br>(only applicable to o1, o3-mini reasoning models)",
            "required": false,
            "type": "dropdown",
            "choices": [
                {
                    "value": "low",
                    "name": "low"
                },
                {
                    "value": "medium",
                    "name": "medium"
                },
                {
                    "value": "high",
                    "name": "high"
                }
            ],
            "default": "medium"
        },
        {
            "key": "whisper-language",
            "name": "<b>Whisper Language</b> default: <i>English</i><br>(Language spoken in the audio)",
            "required": false,
            "type": "text",
            "default": "en"
        },
        {
            "key": "whisper-temperature",
            "name": "<b>Whisper Temperature</b> default: <i>0</i><br>(Temperature for the Whisper model)",
            "required": false,
            "type": "number",
            "min": 0,
            "max": 1,
            "default": 0.0
        },
        {
            "key": "whisper-top-p",
            "name": "<b>Whisper Top P</b> default: <i>1.0</i><br>(Top P for the Whisper model)",
            "required": false,
            "type": "number",
            "min": 0,
            "max": 1,
            "default": 1.0
        },
        {
            "key": "whisper-n",
            "name": "<b>Whisper N</b> default: <i>1</i><br>(Number of candidates to generate)",
            "required": false,
            "type": "number",
            "default": 1
        },
        {
            "key": "whisper-logprobs",
            "name": "<b>Whisper Logprobs</b> default: <i>null</i><br>(Log probabilities for the top n tokens)",
            "required": false,
            "type": "number",
            "default": null
        },
        {
            "key": "whisper-max-alternate-transcriptions",
            "name": "<b>Whisper Max Alternate Transcriptions</b> default: <i>1</i><br>(Maximum number of alternate transcriptions)",
            "required": false,
            "type": "number",
            "default": 1
        },
        {
            "key": "whisper-compression-rate",
            "name": "<b>Whisper Compression Rate</b> default: <i>1.0</i><br>(Compression rate for audio processing)",
            "required": false,
            "type": "number",
            "min": 0.0,
            "max": 1.0,
            "default": 1.0
        },
        {
            "key": "whisper-sample-rate",
            "name": "<b>Whisper Sample Rate</b> default: <i>16000</i><br>(Sample rate for audio processing in Hz)",
            "required": false,
            "type": "number",
            "default": 16000
        },
        {
            "key": "whisper-condition-on-previous-text",
            "name": "<b>Whisper Condition on Previous Text</b> default: <i>true</i><br>(Condition on previous text when generating next segment)",
            "required": false,
            "type": "checkbox",
            "default": true
        },
        {
            "key": "enable-system-debug-logging",
            "name": "<b>Enable Debug Logging (system-wide)</b><i>(optional)</i> Requires installation and configuration of emLogger",
            "required": false,
            "type": "checkbox"
        }
    ],
    "project-settings": [
        {
            "key": "project_agent_tool_em_prefixes",
            "name": "<b>Agent Tool EM Prefixes</b><br><i>(optional)</i> Comma-separated EM prefixes that provide agent tools for this project. Overrides the system-level default when set.<br>Example: <code>redcap_agent_record_tools,redcap_agent_rexi_tools</code>",
            "type": "textarea",
            "required": false
        },
        {
            "key": "enable-project-usage",
            "name": "<b>Enable Project Usage Dashboard</b><br><i>Shows AI usage analytics for this project</i>",
            "type": "checkbox",
            "required": false
        },
        {
            "key": "project-api-key",
            "name": "<b>Project API Key</b><br><i>(Phase 2 - not yet active)</i> Dedicated API key for this project's AI usage",
            "type": "text",
            "required": false
        },
        {
            "key": "project-monthly-token-limit",
            "name": "<b>Monthly Token Limit</b><br><i>(Phase 3 - not yet active)</i> Maximum tokens per month for this project",
            "type": "text",
            "required": false
        },
        {
            "key": "project-monthly-cost-limit",
            "name": "<b>Monthly Cost Limit ($)</b><br><i>(Phase 3 - not yet active)</i> Maximum estimated cost per month for this project",
            "type": "text",
            "required": false
        }
    ],
    "compatibility": {
        "php-version-min": "",
        "php-version-max": "",
        "redcap-version-min": "",
        "redcap-version-max": ""
    }
}
